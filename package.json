{
  "name": "intentbridge",
  "version": "1.0.0",
  "description": "Gemini-powered multimodal intent extraction engine",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run server\" \"npm run client\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server/server.js",
    "server": "node server/server.js",
    "client": "vite --port 5173"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "vite": "^6.4.1"
  }
}
